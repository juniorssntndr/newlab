{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@newlab/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@newlab/contracts/*": [
        "packages/contracts/src/*"
      ]
    },
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true
  }
}
