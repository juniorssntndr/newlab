{
  "name": "newlab-dental",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "server": "cd backend && npm run server",
    "dev": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "contracts:check": "node scripts/check-contract-compatibility.mjs",
    "ci:contracts": "npm run contracts:check"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
